PORT=3000
SESSION_SECRET=troque-por-uma-frase-secreta-grande
ADMIN_KEY=troque-por-uma-chave-admin-grande

# Crie um App Registration em https://portal.azure.com
# Tipos de conta: somente contas Microsoft pessoais.
MICROSOFT_CLIENT_ID=cole-o-client-id-aqui
MICROSOFT_CLIENT_SECRET=cole-o-client-secret-aqui
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback

# Use um link compartilhado de pasta do OneDrive como destino.
ONEDRIVE_SHARE_URL=

# Alternativa caso nao use link compartilhado: nome da pasta no seu OneDrive.
ONEDRIVE_FOLDER=Uploads do Site

# Destino separado para fotos de quest.
ONEDRIVE_QUEST_SHARE_URL=
ONEDRIVE_QUEST_FOLDER=Fotos de Quest

# Limite por arquivo em MB.
MAX_FILE_MB=500

# Tamanho de cada pedaco enviado pelo navegador ao servidor.
CHUNK_SIZE_MB=5
